# Olivia's Nails — Environment Variables
# Copy this file to .env and fill in your values.

# PostgreSQL connection string (set automatically by Replit)
DATABASE_URL=postgresql://user:password@host/dbname

# Admin panel default password (used only on first run to seed the admin account)
# IMPORTANT: Change this immediately after first login via the Settings page.
ADMIN_PASSWORD=admin123

# Node environment
NODE_ENV=production
